# ── MercadoPago ──────────────────────────────────────────────────────
MP_ACCESS_TOKEN=APP_USR-xxxx
MP_PUBLIC_KEY=APP_USR-xxxx
# Firma de los webhooks de MP (panel de MP → Tus integraciones → Notificaciones
# → Webhooks → "Firma secreta"). SIN esto, /webhook/suscripcion y /webhook/pago
# quedan en modo degradado: aceptan cualquier POST sin verificar que venga
# realmente de MercadoPago. Configurarla es CRÍTICO antes de ir a producción.
MP_WEBHOOK_SECRET=

# ── Token de administración interna (/setup/*, /admin/*) ─────────────
# Separado de MP_ACCESS_TOKEN a propósito — ver comentario en index.js.
# Generá cualquier cadena larga y aleatoria (ej: openssl rand -hex 32).
ADMIN_SECRET=

# ── Puente con tasta-contabilidad (GET/PATCH /pedidos-pendientes) ─────
BRIDGE_TOKEN=

# ── Emails transaccionales (Resend) ───────────────────────────────────
RESEND_API_KEY=

# ── Firebase Admin (lealteck-plataforma) ─────────────────────────────
FIREBASE_PROJECT_ID=lealteck-plataforma
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@lealteck-plataforma.iam.gserviceaccount.com
# En Render: pegar la private key COMPLETA (con -----BEGIN/END----- incluidos)
# Los \n se ingresan como saltos de línea reales en la UI de Render
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n

# ── Servidor ─────────────────────────────────────────────────────────
# URL pública de este servidor (sin barra al final)
SERVER_URL=https://lealteck-server.onrender.com
PORT=3001
