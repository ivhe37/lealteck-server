# ── MercadoPago ──────────────────────────────────────────────────────
MP_ACCESS_TOKEN=APP_USR-xxxx
MP_PUBLIC_KEY=APP_USR-xxxx

# ── Firebase Admin (lealteck-plataforma) ─────────────────────────────
FIREBASE_PROJECT_ID=lealteck-plataforma
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@lealteck-plataforma.iam.gserviceaccount.com
# En Render: pegar la private key COMPLETA (con -----BEGIN/END----- incluidos)
# Los \n se ingresan como saltos de línea reales en la UI de Render
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n

# ── Servidor ─────────────────────────────────────────────────────────
# URL pública de este servidor (sin barra al final)
SERVER_URL=https://lealteck-server.onrender.com
PORT=3001
